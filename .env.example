# PostgreSQL
DATABASE_URL=postgresql://finup:finup@localhost:5433/finup_db

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=crypto_chunks

# LLM
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# CoinGecko
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# ETL
ETL_PRODUCTS=bitcoin,ethereum,solana,cardano
ETL_LOOKBACK_DAYS=90
ETL_INTERVAL_DAYS=1

# ML
ML_CONTAMINATION=0.05
ML_LOOKBACK_DAYS=90
ML_OPPORTUNITY_DELTA_THRESHOLD=0.014
ML_ANOMALY_WINDOW_HOURS=1

# n8n
N8N_WEBHOOK_URL=http://localhost:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=development
